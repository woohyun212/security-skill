# Patterns that MUST match (grep -E, all must match for PASS)
PATTERN_1="X\.509|x509|Certificate details"
PATTERN_2="issuer|Issuer"
PATTERN_3="subject|Subject"
PATTERN_4="validity|Validity|notBefore|notAfter|expir"

# Patterns that must NOT match (any match = FAIL)
ANTIPATTERN_1="command not found|permission denied|fatal error"
ANTIPATTERN_2="Certificate format parsing failed"
