# Patterns that MUST match (grep -E, all must match for PASS)
PATTERN_1="AKIA[A-Z0-9]{16}|password|secret|credential|AWS|api.?key"
PATTERN_2="Secret Scan Results|secret scan|trufflehog|gitleaks|finding"
PATTERN_3="Remediation Recommendations|scan complete|Results file"

# Patterns that must NOT match (any match = FAIL)
ANTIPATTERN_1="Path not found|Please install either trufflehog or gitleaks"
ANTIPATTERN_2="Set the SECSKILL_SCAN_PATH environment variable"
