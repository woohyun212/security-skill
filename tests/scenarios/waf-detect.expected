# Patterns that MUST match (grep -E, all must match for PASS)
PATTERN_1="WAF detection|wafw00f|Manual WAF fingerprinting"
PATTERN_2="XSS payload HTTP status|SQLi payload HTTP status|Detection summary"
PATTERN_3="Normal response code|No WAF detected|is behind|Generic Detection"

# Patterns that must NOT match (any match = FAIL)
ANTIPATTERN_1="command not found|permission denied|fatal error"
ANTIPATTERN_2="curl: \(6\) Could not resolve host"
