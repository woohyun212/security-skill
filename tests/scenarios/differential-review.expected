# Patterns that MUST match (grep -E, all must match for PASS)
PATTERN_1="security|Security|risk|Risk"
PATTERN_2="change|Change|addition|Addition|removal|Removal"
PATTERN_3="diff|Diff|HIGH|MEDIUM|LOW|finding|Finding"

# Patterns that must NOT match (any match = FAIL)
ANTIPATTERN_1="command not found|permission denied|fatal error"
ANTIPATTERN_2="not a git repository|fatal: bad revision"
