# Patterns that MUST match (grep -E, all must match for PASS)
PATTERN_1="Origin reflection test|Baseline CORS"
PATTERN_2="ACAO: |Access-Control-Allow-Origin|<none>"
PATTERN_3="Preflight OPTIONS|access-control|\[INFO\]|\[WARNING\]|\[CRITICAL\]"

# Patterns that must NOT match (any match = FAIL)
ANTIPATTERN_1="command not found|permission denied|fatal error"
ANTIPATTERN_2="curl: \(6\) Could not resolve host"
