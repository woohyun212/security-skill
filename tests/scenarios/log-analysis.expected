# Patterns that MUST match (grep -E, all must match for PASS)
PATTERN_1="brute.force|brute force|failed.*login|Failed.*login|authentication failure|authentication failures"
PATTERN_2="suspicious|anomal|invalid user|Invalid user"
PATTERN_3="Auth Log Analysis|Top IPs|failed SSH|Timeline"

# Patterns that must NOT match (any match = FAIL)
ANTIPATTERN_1="command not found|permission denied|fatal error"
ANTIPATTERN_2="File not found|No such file"
