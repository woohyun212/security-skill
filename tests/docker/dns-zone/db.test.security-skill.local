$TTL 300
@   IN SOA ns1.test.security-skill.local. admin.test.security-skill.local. (
        2024010101 ; serial
        3600       ; refresh
        900        ; retry
        604800     ; expire
        300 )      ; minimum

@       IN NS   ns1.test.security-skill.local.
@       IN NS   ns2.test.security-skill.local.

@       IN A    127.0.0.1
ns1     IN A    127.0.0.1
ns2     IN A    127.0.0.2
www     IN A    127.0.0.1
mail    IN A    127.0.0.3
api     IN A    127.0.0.4
dev     IN A    127.0.0.5
staging IN A    127.0.0.6
admin   IN A    127.0.0.7

www     IN CNAME @
@       IN MX 10 mail.test.security-skill.local.
